# Inventory Example
# Copy to inventory.ini and adjust for your environment

[gitlab_server]
gitlab01 ansible_host=192.168.1.100 ansible_user=deploy

[gitlab_server:vars]
install_method=podman
gitlab_hostname=gitlab.platform-dev.idp.local
gitlab_data_dir=/opt/gitlab/data
gitlab_config_dir=/opt/gitlab/config
gitlab_logs_dir=/opt/gitlab/logs

# For Docker fallback (see docs/GITLAB.md)
# install_method=docker
